# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=
SLACK_MODE=socket

# Anthropic — 둘 중 하나 필수
# (1) API 키 사용 시
ANTHROPIC_API_KEY=sk-ant-...
# (2) Claude Pro/Max 구독 인증 (claude setup-token 으로 발급)
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Wiki repo
WIKI_REPO_URL=git@github.com:amass/leader-wiki.git
WIKI_REPO_BRANCH=main
WIKI_LOCAL_PATH=/workspace/leader-wiki
WIKI_SYNC_INTERVAL_CRON=*/5 * * * *
WIKI_REPO_GITHUB_URL=https://github.com/amass/leader-wiki

# 동작
LOG_LEVEL=info
MAX_CONCURRENT_AGENTS=2
QUEUE_MAX_SIZE=20
AGENT_TIMEOUT_MS=120000
PORT=3000

# 질의 로그 (호스트 ./data/ 에 bind mount된 SQLite)
QUERY_LOG_ENABLED=true
QUERY_LOG_DB_PATH=/workspace/data/queries.db
